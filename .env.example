# ─────────────────────────────────────────────
#  Environment Variables — dami_lak
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── Django ──
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ── Site URL ──
SITE_URL=http://127.0.0.1:8000

# ── Gmail SMTP ──
# Step 1: Enable 2-Step Verification on your Google account.
# Step 2: Go to → Google Account → Security → App Passwords.
# Step 3: Click "Create App Password", choose a name (e.g. "Dami Lak").
# Step 4: Copy the 16-character password and paste it below.
#
# IMPORTANT: Use the App Password, NOT your regular Gmail password.
GMAIL_USER=your_address@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
