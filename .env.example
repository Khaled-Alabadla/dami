# ─────────────────────────────────────────────
#  Environment Variables — dami_lak
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── Django ──
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ── Site URL ──
SITE_URL=http://127.0.0.1:8000

# ── Resend Email API ──
# 1. Sign up at https://resend.com
# 2. Go to API Keys → Create API Key
# 3. Paste the key below
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── From address ──
# Development: use Resend's shared test address (no domain required)
#   EMAIL_FROM=Onboarding <onboarding@resend.dev>
# Production: use your verified domain
#   EMAIL_FROM=دمي <noreply@yourdomain.com>
EMAIL_FROM=Onboarding <onboarding@resend.dev>
