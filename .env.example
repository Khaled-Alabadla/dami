# ─────────────────────────────────────────────────────────────────────────────
#  dami_lak — Environment Variables Template
#
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django core ──────────────────────────────────────────────────────────────
# Generate a strong key:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-strong-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=dami2.pythonanywhere.com

# Full public URL of the site — used inside email links
SITE_URL=https://dami2.pythonanywhere.com

# ── Email ─────────────────────────────────────────────────────────────────────
# Pick ONE block.
# Brevo works on PythonAnywhere free accounts (sends via HTTPS, not SMTP).
# Gmail SMTP is blocked on PythonAnywhere free accounts.

# [A] Brevo — recommended for PythonAnywhere
#     1. Sign up at https://brevo.com (free: 300 emails/day)
#     2. SMTP & API → API Keys → Create a key
#     3. Senders & IPs → Senders → verify the address you put in DEFAULT_FROM_EMAIL
BREVO_API_KEY=xkeysib-your-brevo-api-key
DEFAULT_FROM_EMAIL=دمي <your-verified-sender@example.com>

# [B] Gmail SMTP — local dev or paid hosting with SMTP access
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx  (Google → Security → App Passwords)
